  db-backup:
    image: prodrigestivill/postgres-backup-local:16-alpine
    restart: always
    volumes:
      - ./backups:/backups
    depends_on:
      db:
        condition: service_healthy
    environment:
      - POSTGRES_HOST=db
      - POSTGRES_DB=${DB_NAME:-app}
      - POSTGRES_USER=${DB_USER:-postgres}
      - POSTGRES_PASSWORD=${DB_PASSWORD:-postgres}
      - SCHEDULE=@daily
      - BACKUP_KEEP_DAYS=7
